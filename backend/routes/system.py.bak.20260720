"""
routes/system.py - 系统管理
"""
import os, sys, subprocess
from flask import Blueprint, request
from db_config import db_cursor, api_success, api_error, serialize_rows
from auth import require_auth, jwt_encode

system_bp = Blueprint('system', __name__)


@system_bp.route('/system/health', methods=['GET'])
def health_check():
    """健康检查（无需认证）"""
    try:
        with db_cursor(commit=False) as cur:
            cur.execute("SELECT 1")
            db_ok = cur.fetchone() is not None

        # 磁盘
        disk = subprocess.run(['df', '-h', '/'], capture_output=True, text=True)
        disk_line = disk.stdout.split('\n')[1] if disk.stdout else ''
        disk_parts = disk_line.split() if disk_line else ['', '', '', '', '', '']

        # 扩展: 管道健康监控
        try:
            sys.path.insert(0, os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), 'monitor'))
            from pipeline_health import get_all_health
            pipeline_health = get_all_health(days=7)
        except Exception as pe:
            pipeline_health = {'error': str(pe)[:100]}

        return api_success({
            'service': 'stock-system-v2',
            'port': 8891,
            'status': 'running',
            'database': 'connected' if db_ok else 'disconnected',
            'disk_usage': disk_parts[4] if len(disk_parts) > 4 else 'unknown',
            'version': '2.0.0',
            'pipeline_health': pipeline_health,
        })
    except Exception as e:
        return api_error(str(e))


@system_bp.route('/system/config', methods=['GET'])
@require_auth
def get_config():
    """获取系统配置"""
    try:
        with db_cursor(commit=False) as cur:
            cur.execute("SELECT config_key, config_value, description FROM system_config")
            rows = cur.fetchall()

        config = {}
        for r in rows:
            key = r['config_key']
            if key == 'api_key':
                config[key] = {'value': '***', 'desc': r.get('description', '')}
            else:
                config[key] = {'value': r['config_value'], 'desc': r.get('description', '')}

        return api_success({'config': config})
    except Exception as e:
        return api_error(str(e))


@system_bp.route('/system/config', methods=['PUT'])
@require_auth
def update_config():
    """更新系统配置"""
    try:
        data = request.get_json()
        if not data or 'config_key' not in data or 'config_value' not in data:
            return api_error('缺少 config_key 或 config_value')

        with db_cursor() as cur:
            cur.execute("""
                UPDATE system_config SET config_value=%s WHERE config_key=%s
            """, [data['config_value'], data['config_key']])

        return api_success({'config_key': data['config_key']}, '更新成功')
    except Exception as e:
        return api_error(str(e))


@require_auth
def list_tables():
    """列出数据库表及行数"""
    try:
        with db_cursor(commit=False) as cur:
            cur.execute("""
                SELECT TABLE_NAME, TABLE_ROWS, ENGINE
                FROM information_schema.TABLES
                WHERE TABLE_SCHEMA='stock_db_v2'
                ORDER BY TABLE_NAME
            """)
            rows = cur.fetchall()

        return api_success({
            'database': 'stock_db_v2',
            'tables': serialize_rows(rows),
        })
    except Exception as e:
        return api_error(str(e))


@system_bp.route('/system/backup', methods=['POST'])
@require_auth
def backup():
    """数据库备份"""
    try:
        from datetime import datetime
        ts = dt.now().strftime('%Y%m%d_%H%M%S')
        backup_file = f'/tmp/stock_db_v2_backup_{ts}.sql'

        result = subprocess.run(
            ['mysqldump', '-u', 'root', 'stock_db_v2'],
            capture_output=True, text=True, timeout=120
        )

        if result.returncode != 0:
            return api_error(f'备份失败: {result.stderr[:200]}')

        with open(backup_file, 'w') as f:
            f.write(result.stdout)

        size = os.path.getsize(backup_file)

        return api_success({
            'file': backup_file,
            'size': f'{size / 1024 / 1024:.1f}MB',
            'time': ts,
        })
    except subprocess.TimeoutExpired:
        return api_error('备份超时(>120秒)')
    except Exception as e:
        return api_error(str(e))


@system_bp.route('/system/api-keys', methods=['GET'])
def api_keys():
    """获取API密钥列表（从openclaw_config表）"""
    try:
        keys = []
        try:
            from db_config import get_connection as _gk
            conn = _gk()
            cur = conn.cursor()
            cur.execute("SELECT id, name, provider, api_key, description, is_active, created_at FROM openclaw_config.api_credentials ORDER BY id")
            rows = cur.fetchall()
            for r in rows:
                ak = (r['api_key'] or '') if isinstance(r, dict) else (r[3] or '')
                keys.append({
                    'id': r['id'] if isinstance(r, dict) else r[0],
                    'name': r['name'] if isinstance(r, dict) else r[1],
                    'provider': r['provider'] if isinstance(r, dict) else r[2],
                    'api_key': ak[:10] + '...' if len(ak) > 10 else ak,
                    'api_key_masked': len(ak) > 10,
                    'description': r['description'] if isinstance(r, dict) else (r[4] or ''),
                    'is_active': r['is_active'] if isinstance(r, dict) else r[5],
                })
            cur.close()
            conn.close()
        except:
            pass
        return api_success({'keys': keys})
    except Exception as e:
        return api_error(str(e))


@system_bp.route('/api-keys/<int:key_id>', methods=['GET'])
@require_auth
def api_key_detail(key_id):
    """获取单个API Key明文（供页面"显示"功能使用）"""
    try:
        from db_config import get_connection as _gk
        conn = _gk()
        cur = conn.cursor()
        cur.execute("SELECT id, name, provider, api_key, description, is_active FROM openclaw_config.api_credentials WHERE id=%s", (key_id,))
        r = cur.fetchone()
        cur.close(); conn.close()
        if not r:
            return api_error('Key不存在')
        return api_success({
            'id': r['id'],
            'name': r['name'],
            'api_key': r['api_key'],
            'provider': r['provider'],
            'is_active': bool(r['is_active']),
        })
    except Exception as e:
        return api_error(str(e))


@system_bp.route('/system/cron-status', methods=['GET'])
def cron_status():
    """定时任务状态监控"""
    import os
    from datetime import datetime; now = datetime.now()
    tasks = []

    def _mtime(path, label):
        try:
            ts = os.path.getmtime(path)
            mt = datetime.fromtimestamp(ts)
            hours = (now.timestamp() - ts) / 3600
            if hours < 24:
                return {'last_run': mt.strftime('%Y-%m-%d %H:%M'), 'status': 'ok', 'status_label': '✅ 正常', 'hours_ago': round(hours, 1)}
            elif hours < 48:
                return {'last_run': mt.strftime('%Y-%m-%d %H:%M'), 'status': 'warn', 'status_label': '⚠️ 延迟', 'hours_ago': round(hours, 1)}
            else:
                return {'last_run': mt.strftime('%Y-%m-%d %H:%M'), 'status': 'error', 'status_label': '❌ 异常', 'hours_ago': round(hours, 1)}
        except:
            return {'last_run': '从未执行', 'status': 'not_run', 'status_label': '⏳ 未运行', 'hours_ago': 999}

    tasks.append({'id': 'pipeline', 'name': '📊 数据管道', 'description': '每日17:00 K线→评分→快照', **_mtime('/tmp/stock_pipeline_v2.log', 'pipeline')})
    tasks.append({'id': 'service', 'name': '🚀 后端服务', 'description': 'stock-system-v2 (Port 8891)', 'last_run': '运行中', 'status': 'ok', 'status_label': '🟢 运行中', 'hours_ago': 0})

    # systemd service状态
    import subprocess
    r = subprocess.run(['systemctl', 'is-active', 'stock-system-v2.service'], capture_output=True, text=True)
    if r.stdout.strip() != 'active':
        tasks[1]['status_label'] = '🔴 停止'

    # 磁盘
    r = subprocess.run(['df', '-h', '/'], capture_output=True, text=True)
    disk_line = r.stdout.split('\n')[1] if r.stdout else ''
    disk_parts = disk_line.split() if disk_line else []
    tasks.append({'id': 'disk', 'name': '💾 磁盘', 'description': f'使用率 {disk_parts[4] if len(disk_parts)>4 else "--"}', 'last_run': disk_parts[4] if len(disk_parts)>4 else '--', 'status': 'ok' if disk_parts and int(disk_parts[4].rstrip('%')) < 85 else 'warn', 'status_label': ('🟢 正常' if disk_parts and int(disk_parts[4].rstrip('%')) < 85 else '🟡 偏高'), 'hours_ago': 0})

    return api_success({'tasks': tasks})


@system_bp.route('/system/data-dictionary', methods=['GET'])
def data_dictionary():
    """数据字典"""
    from db_config import db_cursor, api_success, api_error
    try:
        cat = request.args.get('category', '')
        with db_cursor(commit=False) as cur:
            if cat:
                cur.execute("""
                    SELECT id, category, en_key, cn_value, description, sort_order
                    FROM data_dictionary WHERE category=%s ORDER BY sort_order ASC
                """, (cat,))
            else:
                cur.execute("""
                    SELECT id, category, en_key, cn_value, description, sort_order
                    FROM data_dictionary ORDER BY category, sort_order ASC
                """)
            rows = cur.fetchall()
        items = []
        for r in rows:
            items.append({
                'id': r['id'],
                'category': r['category'],
                'en_key': r['en_key'],
                'cn_value': r['cn_value'],
                'description': r['description'] or '',
                'sort_order': r['sort_order'],
            })
        return api_success({'items': items, 'total': len(items)})
    except Exception as e:
        return api_error(str(e))


@system_bp.route('/system/db-tables', methods=['GET'])
def db_tables():
    """数据字典（返回V1兼容格式：表+字段+索引+外键）"""
    try:
        with db_cursor(commit=False) as cur:
            cur.execute("""
                SELECT TABLE_NAME, TABLE_ROWS, ENGINE, TABLE_COMMENT
                FROM information_schema.TABLES
                WHERE TABLE_SCHEMA='stock_db_v2'
                ORDER BY TABLE_ROWS DESC
            """)
            tables_raw = cur.fetchall()
            
            # 构建V1兼容格式
            tables = {}
            columns = {}
            indexes = {}
            foreign_keys = {}
            
            for t in tables_raw:
                name = t['TABLE_NAME']
                tables[name] = {
                    'name': name,
                    'rows': int(t['TABLE_ROWS'] or 0),
                    'engine': t['ENGINE'] or '',
                    'comment': t['TABLE_COMMENT'] or '',
                }
                columns[name] = []
                indexes[name] = {}
            
            # 获取字段信息
            cur.execute("""
                SELECT TABLE_NAME, COLUMN_NAME, COLUMN_TYPE, IS_NULLABLE, 
                       COLUMN_KEY, COLUMN_DEFAULT, EXTRA, COLUMN_COMMENT
                FROM information_schema.COLUMNS
                WHERE TABLE_SCHEMA='stock_db_v2'
                ORDER BY TABLE_NAME, ORDINAL_POSITION
            """)
            for row in cur.fetchall():
                tname = row['TABLE_NAME']
                if tname in columns:
                    columns[tname].append({
                        'name': row['COLUMN_NAME'],
                        'type': row['COLUMN_TYPE'],
                        'nullable': row['IS_NULLABLE'] == 'YES',
                        'key': row['COLUMN_KEY'] or '',
                        'default': row['COLUMN_DEFAULT'],
                        'extra': row['EXTRA'] or '',
                        'comment': row['COLUMN_COMMENT'] or '',
                    })
            
            return api_success({
                'tables': tables,
                'columns': columns,
                'indexes': indexes,
                'foreign_keys': foreign_keys,
            })
    except Exception as e:
        return api_error(str(e))
