+@app.route('/api/v2/strategy/check/<ts_code>', methods=['GET'])
+def api_strategy_check(ts_code):
+    """单只持仓策略检查"""
+    try:
+        c = conn(); cu = c.cursor()
+        cu.execute("SELECT * FROM strategy_signal WHERE ts_code=%s ORDER BY trade_date DESC LIMIT 10", (ts_code,))
+        cols1 = [d[0] for d in cu.description]
+        sig = [dict(zip(cols1, r)) for r in cu.fetchall()]
+        cu.execute("SELECT * FROM portfolio_holdings WHERE ts_code=%s AND status='HOLDING'", (ts_code,))
+        cols2 = [d[0] for d in cu.description]
+        h = cu.fetchone()
+        cu.close(); c.close()
+        return ok({'signals': sig, 'holding': dict(zip(cols2, h)) if h else None})
+    except Exception as e:
+        return err(str(e))
