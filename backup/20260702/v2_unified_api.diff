+@app.route('/api/v2/stock/search', methods=['GET'])
+def api_stock_search():
+    """搜索股票"""
+    try:
+        kw = request.args.get('keyword', '')
+        if not kw: return ok({'stocks': []})
+        c = conn(); cu = c.cursor()
+        cu.execute("SELECT ts_code, name, industry, market FROM stock_basic WHERE name LIKE %s OR ts_code LIKE %s LIMIT 20",
+                   [f'%{kw}%', f'%{kw}%'])
+        cols = [d[0] for d in cu.description]
+        rows = [dict(zip(cols, r)) for r in cu.fetchall()]
+        cu.close(); c.close()
+        return ok({'stocks': rows})
+    except Exception as e:
+        return err(str(e))
+
