+@app.route('/api/v2/stock/<ts_code>', methods=['GET'])
+def api_stock_detail(ts_code):
+    """股票详情"""
+    try:
+        c = conn(); cu = c.cursor()
+        cu.execute("SELECT * FROM stock_basic WHERE ts_code=%s", (ts_code,))
+        cols = [d[0] for d in cu.description]
+        r = cu.fetchone()
+        cu.close(); c.close()
+        return ok({'stock': dict(zip(cols, r)) if r else None})
+    except Exception as e:
+        return err(str(e))
