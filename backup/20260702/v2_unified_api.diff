+@app.route('/api/v2/intraday/signals', methods=['GET'])
+def api_intraday_signals():
+    """盘中信号"""
+    try:
+        td = request.args.get('trade_date', '')
+        tc = request.args.get('ts_code', '')
+        limit = min(int(request.args.get('limit', 310)), 620)
+        c = conn(); cu = c.cursor()
+        sql = "SELECT * FROM intraday_signals WHERE 1=1"; p = []
+        if td: sql += " AND trade_date=%s"; p.append(td)
+        if tc: sql += " AND ts_code LIKE %s"; p.append('%' + tc + '%')
+        sql += " ORDER BY check_time DESC LIMIT %s"; p.append(limit)
+        cu.execute(sql, p)
+        cols = [d[0] for d in cu.description]
+        rows = [dict(zip(cols, r)) for r in cu.fetchall()]
+        cu.close(); c.close()
+        for r in rows:
+            for k, v in list(r.items()):
+                if hasattr(v, 'isoformat'): r[k] = str(v)
+                elif hasattr(v, 'seconds'): r[k] = str(v)
+                elif isinstance(v, (bytes, bytearray)): r[k] = str(v, 'utf-8')
+        return ok({'data': rows, 'total': len(rows)})
+    except Exception as e:
+        import traceback;return err(str(e)+'|'+traceback.format_exc()[:300])
+
